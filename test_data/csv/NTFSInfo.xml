<?xml version="1.0" encoding="UTF-8"?>
<plugin parser="Csv" file_encoding="UTF_8">
  <mapping data_type="ntfs_info">
    <description>Parse data the NTFS Info csv file</description>
    <default_parser value="Ignore" />
    <default_date_pattern value='%Y-%m-%d %H:%M:%S.%3f' />
    <csv_delimiter value="," />

    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="MacbMacb" />
      <max_date_meaning value="0" />
      <source_type value="file" />
      <description>
        <output_name value="file_path" />
      </description>
      <additional_description include_field_name="true" field_separator=" - ">
        <output_name value="file_size" />
      </additional_description>
    </timeline>

    <fields>
      <field input="SnapshotID" output="snapshot_id" parser="String" />
      <multi_input output="file_path" qualifier="FILE_PATH" parser="Join" separator="\"
        avoid_separator_duplication="true">
        <field input="ParentName" parser="String" default_value="\" />
        <field input="File" parser="String" />
      </multi_input>
      <field input="ParentName" output="parent" parser="String" default_value="\" />
      <field input="File" output="file_name" parser="String" />
      <field input="Extension" output="extension" parser="String" />
      <field input="SizeInBytes" output="file_size" parser="Int" qualifier="FILE_SIZE" />
      <field input="RecordInUse" output="file_in_use" parser="Bool" />
      <field input="FRN" parser="Extension" />
      <field input="Attributes" parser="Extension" />
      <field input="USN" output="usn_number" parser="IntRadix" radix="16" qualifier="FS_USN" />
      <field input="FilenameFlags" output="file_name_flags" parser="Int" />
      <!-- date fields -->
      <field input="FileNameCreationDate" output="fn_creation_date" parser="DateTime"
        qualifier="DATE_CREATION" />
      <field input="FileNameLastModificationDate" output="fn_lastmod_date" parser="DateTime"
        qualifier="DATE_MODIFICATION" />
      <field input="FileNameLastAccessDate" output="fn_lastaccess_date" parser="DateTime"
        qualifier="DATE_ACCESS" />
      <field input="FileNameLastAttrModificationDate" output="fn_lastchange_date" parser="DateTime"
        qualifier="DATE_CHANGE" />
      <field input="CreationDate" output="si_creation_date" parser="DateTime"
        qualifier="DATE_CREATION" />
      <field input="LastModificationDate" output="si_lastmod_date" parser="DateTime"
        qualifier="DATE_MODIFICATION" />
      <field input="LastAccessDate" output="si_lastaccess_date" parser="DateTime"
        qualifier="DATE_ACCESS" />
      <field input="LastAttrChangeDate" output="si_lastchange_date" parser="DateTime"
        qualifier="DATE_MODIFICATION" />

      <!-- hash -->
      <field input="MD5" output="md5" parser="String" qualifier="FILE_MD5" />
      <field input="SHA-1" output="sha1" parser="String" qualifier="FILE_SHA1" />
      <field input="SHA256" output="sha256" parser="String" qualifier="FILE_SHA256" />
      <field input="PeMD5" output="orc_pe_md5" parser="String" qualifier="PE_MD5" />
      <field input="PeSHA1" output="orc_pe_sha1" parser="String" qualifier="PE_SHA1" />
      <field input="PeSHA256" output="orc_pe_sha256" parser="String" qualifier="PE_SHA256" />
      <field input="SignedHash" output="signed_hash" parser="Extension" />

      <!-- authenticode -->
      <field input="AuthenticodeSigner" output="authenticode_signer" parser="String" />
      <field input="AuthenticodeSignerThumbprint" output="authenticode_signer_thumbprint"
        parser="Split" split_by=";" />
      <field input="AuthenticodeCA" output="authenticode_ca" parser="String" />
      <field input="AuthenticodeCAThumbprint" output="authenticode_ca_thumbprint" parser="Split"
        split_by=";" />
      <field input="AuthenticodeStatus" output="authenticode_status" parser="String" />

      <!-- Others -->
      <field input="Version" output="pe_version" parser="String" qualifier="PE_VERSION" />
      <field input="CompanyName" output="pe_companyname" parser="String" qualifier="COMPANY" />
      <field input="ProductName" output="pe_productname" parser="String" qualifier="PRODUCT" />
      <field input="OriginalFileName" output="pe_original_filename" parser="String"
        qualifier="FILE_NAME" />
      <field input="Platform" output="pe_platform" parser="String" qualifier="PE_ARCH" />
      <field input="SubSystem" output="pe_subsystem" parser="String" qualifier="PE_SUBSYSTEM" />


    </fields>
  </mapping>

</plugin>